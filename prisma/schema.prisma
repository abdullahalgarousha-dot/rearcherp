  @@unique([teamId, userId])
}

/// Individual productivity task — separate from the Gantt Task model.
/// Links optionally to a Project and/or a DesignStage for traceability.
model EmployeeTask {
  id                   String    @id @default(cuid())
  tenantId             String
  title                String
  description          String?
  /// Who the task is assigned to (required)
  assigneeId           String
  /// Who created / assigned the task
  assignedById         String?
  /// Optional link to a Project
  projectId            String?
  /// Optional link to a Gantt DesignStage (for Gantt integration)
  designStageId        String?
  /// Optional link to a Team
  teamId               String?
  /// PENDING | IN_PROGRESS | COMPLETED | CANCELLED
  status               String    @default("PENDING")
  /// LOW | MEDIUM | HIGH | URGENT
  priority             String    @default("MEDIUM")
  plannedStartDate     DateTime?
  plannedEndDate       DateTime?
  /// Set when the task is completed — used for productivity calculation
  actualCompletionDate DateTime?
  estimatedHours       Float?
  actualHours          Float?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignee    User         @relation("EmployeeTaskAssignee", fields: [assigneeId], references: [id])
  assignedBy  User?        @relation("EmployeeTaskCreator", fields: [assignedById], references: [id])
  project     Project?     @relation(fields: [projectId], references: [id])
  designStage DesignStage? @relation(fields: [designStageId], references: [id])
  team        Team?        @relation(fields: [teamId], references: [id])
}

