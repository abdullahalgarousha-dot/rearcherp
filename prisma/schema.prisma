  user         User     @relation(fields: [userId], references: [id])
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── Financial Ledger — cross-domain audit trail ───────────────────────────────
// Every monetary event that originates in HR (loan disbursement, salary payment,
// penalty deduction) posts an immutable entry here so Finance can reconcile
// without joining HR tables directly.
model FinancialLedger {
  id            String   @id @default(cuid())
  tenantId      String
  projectId     String
  /// EXPENSE | INCOME
  type          String
  /// "Employee Advances" | "Salary" | "Loan Repayment" | "Penalty Deduction"
  category      String
  description   String
  amount        Float
  /// LOAN_REQUEST | SALARY_SLIP | PENALTY | DISCIPLINARY
  referenceType String?
  referenceId   String?
  isLocked      Boolean  @default(false)
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── KPI Evaluation — automated monthly performance score ──────────────────────
// Scores are computed by calculateMonthlyKPI() and can be re-run any time.
// unique(userId, month, year) ensures one canonical record per employee per month.
model KpiEvaluation {
  id                String   @id @default(cuid())
  tenantId          String
  userId            String
  evaluatorId       String?
  month             Int
  year              Int
  /// 0–100 composite score
  totalScore        Float    @default(0)
  /// 0–50  — task completion + long-task bonuses/penalties
  taskScore         Float    @default(0)
  /// 0–30  — logged hours / required hours * 30
  timesheetScore    Float    @default(0)
  /// 0–20  — disciplinary actions deduction
  disciplinePenalty Float    @default(0)
  feedback          String?
  /// JSON blob with per-component breakdown for the tooltip
  breakdown         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user      User    @relation("UserKPIs",      fields: [userId],      references: [id], onDelete: Cascade)
  evaluator User?   @relation("EvaluatorKPIs", fields: [evaluatorId], references: [id])
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

model FinanceAuditTrail {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  action     String
  entityId   String
  entityType String
  details    String
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ProjectType {
  id        String   @id @default(cuid())
  tenantId  String
  nameEn    String
  nameAr    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects  Project[]
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
