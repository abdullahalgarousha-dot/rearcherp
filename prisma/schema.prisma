generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ClientType {
  INDIVIDUAL
  COMPANY
}

model SubscriptionPlan {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String?
  price          Float    @default(0)
  currency       String   @default("SAR")
  allowedModules Json     @default("[]")
  maxUsers       Int      @default(0) // 0 = unlimited
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenants        Tenant[]
}

model Tenant {
  id                 String                  @id @default(cuid())
  slug               String                  @unique
  name               String
  status             String                  @default("ACTIVE")
  subscriptionTier   String                  @default("STANDARD")
  driveClientId      String?
  driveClientSecret  String?
  driveRefreshToken  String?
  driveRootFolderId  String?
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?
  setupCompleted     Boolean                 @default(false)
  customDomain       String?                 @unique
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  planId             String?
  attendances        Attendance[]
  auditLogs          AuditLog[]
  branches           Branch[]
  brands             Brand[]
  clients            Client[]
  companyEvents      CompanyEvent[]
  companyProfiles    CompanyProfile[]
  complaints         Complaint[]
  contractors        Contractor[]
  dailyReports       DailyReport[]
  designStages       DesignStage[]
  designStageFiles   DesignStageFile[]
  documentRequests   DocumentRequest[]
  drawings           Drawing[]
  drawingRevisions   DrawingRevision[]
  hrStats            EmployeeHRStats[]
  employeeProfiles   EmployeeProfile[]
  expenses           Expense[]
  fileComments       FileComment[]
  irRevisions        IRRevision[]
  inAppNotifications InAppNotification[]
  inspectionRequests InspectionRequest[]
  invoices           Invoice[]
  invoiceItems       InvoiceItem[]
  leaveRequests      LeaveRequest[]
  loans              Loan[]
  loanRequests         LoanRequest[]
  permissionRequests   PermissionRequest[]
  disciplinaryActions  DisciplinaryAction[]
  loginAttempts        LoginAttempt[]
  materialSubmittals MaterialSubmittal[]
  menuLinks          MenuLink[]
  milestones         Milestone[]
  ncrs               NCR[]
  ncrRevisions       NCRRevision[]
  notifications      Notification[]
  penalties          Penalty[]
  pettyCashRequests  PettyCashRequest[]
  custodySettlements CustodySettlementItem[]
  projects           Project[]
  roles              Role[]
  salarySlips        SalarySlip[]
  subContracts       SubContract[]
  systemLogs         SystemLog[]
  systemLookups      SystemLookup[]
  systemSettings     SystemSetting[]
  tasks              Task[]
  taskComments       TaskComment[]
  plan               SubscriptionPlan?       @relation(fields: [planId], references: [id])
  timeLogs           TimeLog[]
  users              User[]
  workLogs           WorkLog[]
  variationOrders    VariationOrder[]
  teams              Team[]
  employeeTasks      EmployeeTask[]
  vendors            Vendor[]
  vendorContracts    VendorContract[]
  leads              Lead[]
  proposals          Proposal[]
  proposalRevisions  ProposalRevision[]
  reportAttendees    ReportAttendee[]
  rolePermissions    RolePermission[]
  loanPayments       LoanPayment[]
  financialLedger    FinancialLedger[]
  kpiEvaluations     KpiEvaluation[]
  financeAuditTrails FinanceAuditTrail[]
  projectTypes       ProjectType[]
}

model User {
  id                    String                  @id @default(cuid())
  tenantId              String
  name                  String?
  email                 String                  @unique
  emailVerified         DateTime?
  image                 String?
  password              String?
  role                  String                  @default("SITE_ENGINEER")
  accessScope           String                  @default("ALL")             // BRANCH | ALL
  twoFactorSecret       String?
  twoFactorEnabled      Boolean                 @default(false)
  roleId                String?
  attendances           Attendance[]
  approvedReports       DailyReport[]           @relation("ApprovedReports")
  createdReports        DailyReport[]           @relation("CreatedReports")
  uploadedDesignFiles   DesignStageFile[]
  approvedDrawings      DrawingRevision[]       @relation("DrawingApprovers")
  uploadedDrawings      DrawingRevision[]
  profile               EmployeeProfile?
  fileComments          FileComment[]
  irResponses           IRRevision[]            @relation("RespondedIRRevisions")
  irRevisions           IRRevision[]            @relation("CreatedIRRevisions")
  notificationsReceived InAppNotification[]     @relation("UserNotifications")
  approvedIRs           InspectionRequest[]     @relation("ApprovedIRs")
  createdIRs            InspectionRequest[]     @relation("CreatedIRs")
  approvedLeaves        LeaveRequest[]          @relation("ApproverLeaves")
  reviewedLeaves        LeaveRequest[]          @relation("ReviewerLeaves")
  leaveRequests         LeaveRequest[]          @relation("UserLeaves")
  approvedSubmittals    MaterialSubmittal[]     @relation("ApprovedSubmittals")
  approvedNCRs          NCR[]                   @relation("ApprovedNCRs")
  createdNCRs           NCR[]                   @relation("CreatedNCRs")
  ncrResponses          NCRRevision[]           @relation("RespondedNCRRevisions")
  ncrRevisions          NCRRevision[]           @relation("CreatedNCRRevisions")
  notifications         Notification[]
  pettyCashRequests     PettyCashRequest[]      @relation("CustodyRequester")
  closedCustodies       PettyCashRequest[]      @relation("CustodyCloser")
  custodySettlements    CustodySettlementItem[]
  leadProjects          Project[]               @relation("LeadEngineer")
  reportAttendances     ReportAttendee[]
  systemLogs            SystemLog[]
  timeLogs              TimeLog[]
  userRole              Role?                   @relation(fields: [roleId], references: [id])
  tenant                Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  approvedVOs           VariationOrder[]
  paidMilestones        VendorMilestone[]       @relation("PaidMilestones")
  workLogs              WorkLog[]
  assignedStages        DesignStage[]           @relation("DesignStageUsers")
  projects              Project[]               @relation("ProjectEngineers")
  assignedTasks         Task[]                  @relation("TaskAssignees")
  taskComments          TaskComment[]

  // Reporting line (direct manager within the User table)
  managerId    String?
  manager      User?   @relation("UserReportsTo", fields: [managerId], references: [id])
  subordinates User[]  @relation("UserReportsTo")

  // Productivity & Task module
  teamMemberships       TeamMember[]
  ledTeams              Team[]         @relation("TeamLeader")
  assignedEmployeeTasks EmployeeTask[] @relation("EmployeeTaskAssignee")
  createdEmployeeTasks  EmployeeTask[] @relation("EmployeeTaskCreator")
  permissionRequests    PermissionRequest[]
  disciplinaryActions   DisciplinaryAction[]
  kpiEvaluations        KpiEvaluation[]         @relation("UserKPIs")
  evaluatedKPIs         KpiEvaluation[]         @relation("EvaluatorKPIs")
}

model EmployeeProfile {
  id                 String            @id @default(cuid())
  userId             String            @unique
  employeeCode       String?
  department         String
  position           String
  directManagerId    String?
  nationality        String?
  googleEmail        String?
  photo              String?
  idNumber           String?
  idExpiry           DateTime?
  passportNum        String?
  passportExpiry     DateTime?
  hireDate           DateTime?
  leaveBalance       Int               @default(21)
  employmentType     String            @default("PERMANENT") // PERMANENT | CONTRACT | PROBATION
  insuranceProvider  String?
  insurancePolicy    String?
  insuranceExpiry    DateTime?
  insuranceClass     String?
  basicSalary        Float             @default(0)
  housingAllowance   Float             @default(0)
  transportAllowance Float             @default(0)
  otherAllowance     Float             @default(0)
  gosiDeduction      Float             @default(0)
  totalSalary        Float             @default(0)
  hourlyRate         Float?
  iban               String?
  bankName           String?
  legacyBranch       String?           @map("branch")
  legacyCurrency     String?           @default("SAR") @map("currency")
  branchId           String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  tenantId           String
  complaints         Complaint[]
  documentRequests   DocumentRequest[]
  hrStats            EmployeeHRStats?
  assignedBranch     Branch?           @relation(fields: [branchId], references: [id])
  directManager      EmployeeProfile?  @relation("ManagerSubordinates", fields: [directManagerId], references: [id])
  subordinates       EmployeeProfile[] @relation("ManagerSubordinates")
  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeLoans        Loan[]
  loans              LoanRequest[]
  penalties          Penalty[]
  salarySlips        SalarySlip[]

  @@unique([tenantId, employeeCode])
}

model Role {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  description      String?
  permissionMatrix String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users            User[]

  @@unique([tenantId, name])
}

model RolePermission {
  id         String   @id @default(cuid())
  tenantId   String
  roleName   String
  module     String
  canRead    Boolean  @default(false)
  canWrite   Boolean  @default(false)
  canApprove Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, roleName, module])
}

model CompanyProfile {
  id                 String   @id @default(cuid())
  tenantId           String
  companyNameAr      String   @default("اسم الشركة")
  companyNameEn      String   @default("Company Name")
  logoUrl            String?
  vatNumber          String?
  crNumber           String?
  nationalAddress    String?
  vatPercentage      Float    @default(15)
  defaultCurrency    String   @default("SAR")
  contactEmail       String?
  contactPhone       String?
  address            String?

  // ZATCA & National Address fields
  buildingNumber     String?
  streetName         String?
  district           String?
  city               String?
  postalCode         String?
  additionalNumber   String?
  zatcaApiToken      String?
  driveClientId      String?
  driveClientSecret  String?
  driveRefreshToken  String?
  driveFolderId      String?
  workingHoursPerDay Float    @default(8)
  workingDaysPerWeek Int      @default(5)
  weekendDays        String   @default("Friday,Saturday")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String
  type            String
  startDate       DateTime
  endDate         DateTime
  reason          String?
  status          String   @default("PENDING")
  rejectionReason String?
  attachmentLink  String?
  reviewerId      String?
  approverId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  approver        User?    @relation("ApproverLeaves", fields: [approverId], references: [id])
  reviewer        User?    @relation("ReviewerLeaves", fields: [reviewerId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User     @relation("UserLeaves", fields: [userId], references: [id])
}

model Brand {
  id            String    @id @default(cuid())
  tenantId      String
  nameEn        String
  nameAr        String
  shortName     String?
  fullName      String?
  logoUrl       String?
  primaryColor  String?   @default("#10b981")
  accentColor   String?   @default("#059669")
  taxNumber     String?
  crNumber      String?
  abbreviation  String? // Prefix for ID generation (e.g., 'FTS')
  nationalAddress String? // ZATCA National Address
  isDefault     Boolean   @default(false)
  email         String?
  phone         String?
  address       String?
  vatNumber     String?
  bankName      String?
  iban          String?
  accountHolder String?
  addressAr     String?
  addressEn     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects      Project[]
  leads         Lead[]
  proposals     Proposal[]
}

model Project {
  id                    String                  @id @default(cuid())
  tenantId              String
  code                  String
  name                  String
  legacyClientName      String?                 @map("client")
  legacyClientAddr      String?                 @map("clientAddress")
  legacyClientVat       String?                 @map("clientVat")
  legacyClientBio       String?                 @map("clientBio")
  contractValue         Float
  vatAmount             Float?
  clientId              String?
  hasRetention          Boolean                 @default(false)
  retentionPercentage   Float                   @default(0)
  totalRetentionHeld    Float                   @default(0)
  originalContractValue Float                   @default(0)
  startDate             DateTime?
  totalDuration         Int?
  contractDuration      Int?
  completionPercent     Float                   @default(0)
  brandId               String?
  branchId              String?
  year                  Int
  sequence              Int
  leadEngineerId        String?
  disciplines           String?
  driveFolderId         String?
  driveLink             String?
  driveSubFolderIds     String?
  serviceType           String                  @default("DESIGN")
  status                String                  @default("ACTIVE")
  autoArchiveToDrive    Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  dailyReports          DailyReport[]
  designStages          DesignStage[]
  drawings              Drawing[]
  expenses              Expense[]
  irs                   InspectionRequest[]
  invoices              Invoice[]
  milestones            Milestone[]
  ncrs                  NCR[]
  pettyCashRequests     PettyCashRequest[]
  custodySettlements    CustodySettlementItem[]
  branch                Branch?                 @relation(fields: [branchId], references: [id])
  brand                 Brand?                  @relation(fields: [brandId], references: [id], onDelete: SetNull)
  client                Client?                 @relation(fields: [clientId], references: [id])
  leadEngineer          User?                   @relation("LeadEngineer", fields: [leadEngineerId], references: [id])
  tenant                Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectContractors    ProjectContractor[]
  subContracts          SubContract[]
  tasks                 Task[]
  timeLogs              TimeLog[]
  variationOrders       VariationOrder[]
  vendorContracts       VendorContract[]
  workLogs              WorkLog[]
  financialLedgers      FinancialLedger[]
  engineers             User[]                  @relation("ProjectEngineers")
  projectTypeId         String?
  projectType           ProjectType?            @relation(fields: [projectTypeId], references: [id])
  employeeTasks         EmployeeTask[]

  @@unique([tenantId, code])
}

model ProjectContractor {
  id            String     @id @default(cuid())
  projectId     String
  contractorId  String
  startDate     DateTime   @default(now())
  durationDays  Int        @default(0)
  contractValue Float      @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  contractor    Contractor @relation(fields: [contractorId], references: [id])
  project       Project    @relation(fields: [projectId], references: [id])

  @@unique([projectId, contractorId])
}

model Contractor {
  id                 String              @id @default(cuid())
  tenantId           String
  companyName        String
  contactPerson      String?
  phone              String?
  email              String?
  specialty          String?
  crNumber           String?
  logo               String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dailyReports       DailyReport[]
  irs                InspectionRequest[]
  ncrs               NCR[]
  projectContractors ProjectContractor[]
  vendorContracts    VendorContract[]    @relation("VendorContractor")
}

model Task {
  id            String        @id @default(cuid())
  tenantId      String
  projectId     String?
  title         String
  description   String?
  status        String        @default("TO_DO")
  start         DateTime      @default(now())
  end           DateTime      @default(now())
  progress      Float         @default(0)
  dependencies  String?
  type          String        @default("OFFICE")
  designStageId String?
  delayReason   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  designStage   DesignStage?  @relation(fields: [designStageId], references: [id])
  project       Project?      @relation(fields: [projectId], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workLogs      WorkLog[]
  timeLogs      TimeLog[]
  assignees     User[]        @relation("TaskAssignees")
  comments      TaskComment[]
}

model TaskComment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model WorkLog {
  id          String   @id @default(cuid())
  tenantId    String
  projectId   String
  taskId      String?
  userId      String
  date        DateTime
  hoursLogged Float
  type        String   @default("OFFICE")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id])
  task        Task?    @relation(fields: [taskId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TimeLog {
  id          String   @id @default(cuid())
  tenantId    String
  projectId   String
  taskId      String?
  userId      String
  date        DateTime
  hoursLogged Float
  type        String   @default("OFFICE")
  cost        Float    @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id])
  task        Task?    @relation(fields: [taskId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])
}

model DailyReport {
  id                   String      @id @default(cuid())
  tenantId             String
  createdById          String
  approvedById         String?
  projectId            String
  date                 DateTime
  status               String      @default("PENDING")
  content              String?
  completionPercentage Float?
  currentCompletion    Float       @default(0)
  sitePhotos           String?
  officeRef            String?
  serial               Int         @default(1)
  elapsedDays          Int?
  contractorId         String?
  totalManpower        Int?
  materialsDelivered   String?
  weather              String?
  workPerformedToday   String?
  plannedWorkTomorrow  String?
  consultantStaff      String?
  contractorData       String?
  equipment            String?
  delayDays            Int?
  safetyStatus         String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  approvedBy           User?       @relation("ApprovedReports", fields: [approvedById], references: [id])
  contractor           Contractor? @relation(fields: [contractorId], references: [id])
  createdBy            User        @relation("CreatedReports", fields: [createdById], references: [id])
  project              Project     @relation(fields: [projectId], references: [id])
  tenant               Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model NCR {
  id           String        @id @default(cuid())
  tenantId     String
  createdById  String
  approvedById String?
  projectId    String
  officeRef    String?
  contractorId String?
  currentRev   Int           @default(0)
  status       String        @default("PENDING")
  severity     String?
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  approvedBy   User?         @relation("ApprovedNCRs", fields: [approvedById], references: [id])
  contractor   Contractor?   @relation(fields: [contractorId], references: [id])
  createdBy    User          @relation("CreatedNCRs", fields: [createdById], references: [id])
  project      Project       @relation(fields: [projectId], references: [id])
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  revisions    NCRRevision[]
}

model InspectionRequest {
  id               String       @id @default(cuid())
  tenantId         String
  createdById      String
  approvedById     String?
  projectId        String
  contractorId     String?
  status           String       @default("PENDING")
  type             String
  date             DateTime
  description      String?
  contractorRef    String?
  officeRef        String?
  serial           Int          @default(1)
  revision         Int          @default(0)
  currentRev       Int          @default(0)
  contractorReport String?
  taskId           String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  revisions        IRRevision[]
  approvedBy       User?        @relation("ApprovedIRs", fields: [approvedById], references: [id])
  contractor       Contractor?  @relation(fields: [contractorId], references: [id])
  createdBy        User         @relation("CreatedIRs", fields: [createdById], references: [id])
  project          Project      @relation(fields: [projectId], references: [id])
  tenant               Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model MaterialSubmittal {
  id           String   @id @default(cuid())
  tenantId     String
  approvedById String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  approvedBy   User?    @relation("ApprovedSubmittals", fields: [approvedById], references: [id])
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ReportAttendee {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model IRRevision {
  id                String            @id @default(cuid())
  tenantId          String
  irId              String
  userId            String
  respondedById     String?
  revNumber         Int               @default(0)
  consultantFile    String?
  contractorFile    String?
  comments          String?
  status            String            @default("PENDING")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  inspectionRequest InspectionRequest @relation(fields: [irId], references: [id])
  respondedBy       User?             @relation("RespondedIRRevisions", fields: [respondedById], references: [id])
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User              @relation("CreatedIRRevisions", fields: [userId], references: [id])
}

model NCRRevision {
  id             String   @id @default(cuid())
  tenantId       String
  ncrId          String
  userId         String
  respondedById  String?
  revNumber      Int      @default(0)
  consultantFile String?
  contractorFile String?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ncr            NCR      @relation(fields: [ncrId], references: [id])
  respondedBy    User?    @relation("RespondedNCRRevisions", fields: [respondedById], references: [id])
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User     @relation("CreatedNCRRevisions", fields: [userId], references: [id])
}

model Attendance {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  date      DateTime
  checkIn   DateTime?
  checkOut  DateTime?
  status    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])
}

model SystemLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  action    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model DesignStage {
  id            String            @id @default(cuid())
  tenantId      String
  projectId     String
  name          String
  order         Int               @default(0)
  progress      Float             @default(0)
  status        String            @default("PENDING")
  description   String?
  startDate     DateTime?
  endDate       DateTime?
  specialties   String?
  requirements  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  project       Project           @relation(fields: [projectId], references: [id])
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  files         DesignStageFile[]
  tasks         Task[]
  assignees     User[]            @relation("DesignStageUsers")
  employeeTasks EmployeeTask[]
}

model DesignStageFile {
  id           String      @id @default(cuid())
  tenantId     String
  stageId      String
  name         String?
  uploadedById String?
  url          String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  stage        DesignStage @relation(fields: [stageId], references: [id])
